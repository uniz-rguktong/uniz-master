# UniZ Production Environment Configuration
# Copy this file to .env and fill in the values

# --- DATABASE CONFIGURATION ---
# Leave these blank/commented to use the internal Postgres container.
# Fill them to connect to an external Neon DB instance.

# AUTH_DATABASE_URL=postgresql://user:password@neon-host:5432/uniz_db?sslmode=require&schema=auth
# USER_DATABASE_URL=postgresql://user:password@neon-host:5432/uniz_db?sslmode=require&schema=users
# OUTPASS_DATABASE_URL=postgresql://user:password@neon-host:5432/uniz_db?sslmode=require&schema=outpass
# ACADEMICS_DATABASE_URL=postgresql://user:password@neon-host:5432/uniz_db?sslmode=require&schema=academics
# FILES_DATABASE_URL=postgresql://user:password@neon-host:5432/uniz_db?sslmode=require&schema=files
# CRON_DATABASE_URL=postgresql://user:password@neon-host:5432/uniz_db?sslmode=require&schema=public

# --- REDIS CONFIGURATION ---
# Leave blank to use the internal Redis container.
# REDIS_URL=redis://your-external-redis:6379

# --- SYSTEM SECRETS ---
INTERNAL_SECRET=uniz-core-secure-secret-replace-me
JWT_SECURITY_KEY=uniz-jwt-production-replace-me

# --- GATEWAY CONFIG ---
# Change this to your VPS IP or Domain (e.g., http://1.2.3.4/api/v1)
GATEWAY_URL=http://localhost/api/v1

# --- CORS ALLOWED ORIGINS ---
# Frontend URLs that can make requests to the API
# Add your production frontend URL here when deploying
CLIENT_URL=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://127.0.0.1:5173

# --- MAIL CONFIG (SMTP) ---
SMTP_HOST=smtp.ethereal.email
SMTP_USER=test-user
SMTP_PASS=test-pass
SMTP_PORT=587
SMTP_SECURE=false

# --- CLOUDINARY CONFIG ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset

# --- SERVICES CONFIG ---
# These are internal defaults, usually don't need changing
NODE_ENV=production
DOCKER_ENV=true

# --- DOCKER HUB CONFIG (For developers) ---
# --- INTERNAL ROUTING (Optional) ---
# Only change these if you are doing custom network orchestration.
# AUTH_SERVICE_URL=http://uniz-auth-service:3001
# USER_SERVICE_URL=http://uniz-user-service:3002
# ACADEMICS_SERVICE_URL=http://uniz-academics-service:3004
# OUTPASS_SERVICE_URL=http://uniz-outpass-service:3003
# FILES_SERVICE_URL=http://uniz-files-service:3005
# MAIL_SERVICE_URL=http://uniz-mail-service:3006
# NOTIFICATION_SERVICE_URL=http://uniz-notification-service:3007
# CRON_SERVICE_URL=http://uniz-cron-service:3008
