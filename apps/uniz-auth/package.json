{
  "name": "uniz-auth-service",
  "version": "1.0.0",
  "description": "Auth Microservice",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "prisma:generate": "prisma generate",
    "vercel-build": "prisma generate",
    "postinstall": "if [ -f prisma/schema.prisma ]; then npx prisma generate; fi",
    "seed": "ts-node prisma/seed.ts",
    "data-reset": "npx prisma db push --force-reset && npm run seed",
    "deploy": "git add . && git commit -m \"deploy: auth-service updates\" && git push origin main",
    "redeploy": "bash redeploy.sh"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@types/nodemailer": "^6.4.15",
    "axios": "^1.13.4",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.15",
    "tar": "^7.5.9",
    "ua-parser-js": "^2.0.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "@types/ua-parser-js": "^0.7.39",
    "prisma": "^6.4.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "glob": "^10.3.10",
    "tar": "^7.5.9"
  }
}
