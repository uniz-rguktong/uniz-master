{
  "name": "uniz-cron-service",
  "version": "1.0.0",
  "description": "Cron Service for Maintenance",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "prisma:generate": "prisma generate",
    "vercel-build": "prisma generate",
    "postinstall": "if [ -f prisma/schema.prisma ]; then npx prisma generate; fi",
    "redeploy": "bash redeploy.sh"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "@vercel/node": "^5.5.28",
    "axios": "^1.13.5",
    "cors": "^2.8.6",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "redis": "^4.6.10"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "prisma": "^5.19.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "overrides": {
    "undici": "^6.21.0",
    "path-to-regexp": "^6.3.0"
  }
}
