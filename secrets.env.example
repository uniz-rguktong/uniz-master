# UniZ Master Vault Example
# Copy this to secrets.env and fill in the values for local development

# Security
JWT_SECURITY_KEY="local-dev-key-123456"
INTERNAL_SECRET="uniz-core"
INTERNAL_BOT_SECRET="bot-secret-123"

# Infrastructure
REDIS_URL="redis://localhost:6379"

# Databases (Local Docker Compose)
AUTH_DATABASE_URL="postgresql://user:password@localhost:5432/uniz_db?sslmode=disable&schema=uniz_auth"
USER_DATABASE_URL="postgresql://user:password@localhost:5432/uniz_db?sslmode=disable&schema=uniz_user"
ACADEMICS_DATABASE_URL="postgresql://user:password@localhost:5432/uniz_db?sslmode=disable&schema=uniz_academics"
OUTPASS_DATABASE_URL="postgresql://user:password@localhost:5432/uniz_db?sslmode=disable&schema=uniz_outpass"
FILES_DATABASE_URL="postgresql://user:password@localhost:5432/uniz_db?sslmode=disable&schema=uniz_files"
MAIL_DATABASE_URL="postgresql://user:password@localhost:5432/uniz_db?sslmode=disable&schema=uniz_mail"
NOTIFICATION_DATABASE_URL="postgresql://user:password@localhost:5432/uniz_db?sslmode=disable&schema=uniz_notifications"
CRON_DATABASE_URL="postgresql://user:password@localhost:5432/uniz_db?sslmode=disable&schema=uniz_cron"
ORNATE_DATABASE_URL="postgresql://user:password@localhost:5432/ornate_core?schema=public"
ORNATE_DIRECT_URL="postgresql://user:password@localhost:5432/ornate_core?schema=public"

# External Services (Placeholders)
CLOUDINARY_CLOUD_NAME="dgp5srab5"
CLOUDINARY_UPLOAD_PRESET="uniz_upload"
# Cloudflare Turnstile (Testing Keys - Always Pass)
VITE_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
VITE_API_URL="http://localhost:3000/api/v1"
VITE_MAINTENANCE_MODE="false"
VITE_SCRAPER_URL="http://localhost:8080"

# AWS / R2 (Optional for local dev)
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="placeholder"
AWS_SECRET_ACCESS_KEY="placeholder"
SES_FROM_EMAIL="no-reply@localhost"

# Institution
INSTITUTION_LOGO_URL="https://example.com/logo.png"
